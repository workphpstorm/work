{
  "id": null,
  "title": "BullMQ Queue Metrics",
  "tags": ["bullmq", "queue"],
  "timezone": "browser",
  "panels": [
    {
      "type": "graph",
      "title": "Failed Jobs",
      "targets": [
        {
          "expr": "bull_failed_jobs_total",
          "legendFormat": "{{queue}}"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "type": "graph",
      "title": "Retry Attempts",
      "targets": [
        {
          "expr": "bull_retry_attempts_total",
          "legendFormat": "{{queue}}"
        }
      ],
      "datasource": "Prometheus"
    }
  ]
}
